ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_URL=https://api.anthropic.com/v1

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_URL=https://api.openai.com/v1

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Hosted vLLM endpoint (e.g. RunPod proxy)
VLLM_API_URL=https://<runpod-id>-8000.proxy.runpod.net/v1
VLLM_MODEL=nemotron3-nano-4b-fp8

# Langfuse tracing. Setting LANGFUSE_PUBLIC_KEY (with a matching secret)
# wires a LangfuseSink alongside the TUI sink and patches
# openai.Completions.create so LLM generations are auto-captured under
# each agent-turn span. To disable tracing, leave LANGFUSE_PUBLIC_KEY
# empty / commented out.
#
# LANGFUSE_BASE_URL: optional; defaults to https://cloud.langfuse.com (EU).
#                    Set explicitly for the US region or self-hosted.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
